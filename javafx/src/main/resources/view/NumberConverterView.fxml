<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="100.0" prefWidth="200.0" xmlns="http://javafx.com/javafx/8.0.172-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="numberconverter.withfxml.view.NumberConverterController">

         <children>
            <TextField fx:id="numberTextField" alignment="CENTER_RIGHT" text="0">
               <VBox.margin>
                  <Insets bottom="25.0" />
               </VBox.margin></TextField>
            <GridPane hgap="10.0" vgap="10.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints vgrow="SOMETIMES" />
                <RowConstraints vgrow="SOMETIMES" />
                <RowConstraints vgrow="SOMETIMES" />
                  <RowConstraints vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <RadioButton fx:id="decRadioButton" mnemonicParsing="false" selected="true" text="DEC" userData="DEC">
               <toggleGroup>
                  <ToggleGroup fx:id="numberToggleGroup" />
               </toggleGroup>
                  </RadioButton>
                  <RadioButton fx:id="binRadioButton" mnemonicParsing="false" text="BIN" toggleGroup="$numberToggleGroup" userData="BIN" GridPane.rowIndex="1" />
                  <RadioButton fx:id="hexRadioButton" mnemonicParsing="false" text="HEX" toggleGroup="$numberToggleGroup" userData="HEX" GridPane.rowIndex="2" />
                  <RadioButton fx:id="octRadioButton" mnemonicParsing="false" text="OCT" toggleGroup="$numberToggleGroup" userData="OCT" GridPane.rowIndex="3" />
                  <Label fx:id="decLabel" text="Label" GridPane.columnIndex="1" />
                  <Label fx:id="binLabel" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label fx:id="hexLabel" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Label fx:id="octLabel" text="Label" GridPane.columnIndex="1" GridPane.rowIndex="3" />
               </children>
            </GridPane>
         </children>
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
      </VBox>
